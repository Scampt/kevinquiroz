---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title = "Kevin Quiroz — CX Operations & Automation Specialist",
  description = "CX Operations & Automation Specialist. n8n · Chatwoot · Shopify. Automatizo soporte y operaciones para ecommerce en LATAM. Puebla, México — remoto worldwide.",
  canonical = "https://kevinquiroz.com",
  ogImage = "/me.jpg",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`https://kevinquiroz.com${ogImage}`} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:site_name" content="Kevin Quiroz" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@KevinQuirozMX" />
    <meta name="twitter:creator" content="@KevinQuirozMX" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://kevinquiroz.com${ogImage}`} />

    <!-- Theme init: run before render to prevent flash -->
    <script is:inline>
      (function() {
        var saved = localStorage.getItem('kq-theme');
        var system = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', saved || system);
        var sun = document.getElementById('icon-sun');
        var moon = document.getElementById('icon-moon');
        var theme = saved || system;
        if (sun) sun.style.display = theme === 'light' ? 'block' : 'none';
        if (moon) moon.style.display = theme === 'light' ? 'none' : 'block';
      })();
    </script>

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Luis Kevin Quiroz Pacheco",
      "alternateName": "Kevin Quiroz",
      "url": "https://kevinquiroz.com",
      "email": "luis.kevin.quiroz@gmail.com",
      "jobTitle": "CX Operations & Automation Specialist",
      "address": { "@type": "PostalAddress", "addressRegion": "Puebla", "addressCountry": "MX" },
      "sameAs": [
        "https://github.com/scampt",
        "https://www.linkedin.com/in/kevinquirozmx/"
      ]
    })} />
  </head>

  <body>
    <div class="cursor-light" id="cursor-light"></div>

    <!-- ═══════════════════ NAV ═══════════════════ -->
    <nav class="nav" id="nav">
      <div class="nav-inner">
        <a href="#hero" class="brand">
          <span class="mark"></span>
          <span>Kevin Quiroz</span>
        </a>
        <div class="nav-links">
          <a href="#about" class="nav-link" data-i18n="nav_about">Sobre Mí</a>
          <a href="#services" class="nav-link" data-i18n="nav_services">Servicios</a>
          <a href="#projects" class="nav-link" data-i18n="nav_projects">Proyectos</a>
          <a href="#stack" class="nav-link">Stack</a>
          <a href="#notes" class="nav-link" data-i18n="nav_notes">Notas</a>
        </div>
        <div class="nav-actions">
          <div class="lang-group">
            <button class="lang-btn active" id="lang-es" onclick="setLang('es')">ES</button>
            <button class="lang-btn" id="lang-en" onclick="setLang('en')">EN</button>
          </div>
          <button class="theme-btn" id="theme-toggle" type="button" aria-label="Toggle theme">
            <svg id="icon-moon" width="15" height="15" fill="currentColor" viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            <svg id="icon-sun" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24" style="display:none"><circle cx="12" cy="12" r="4" fill="currentColor" stroke="none"/><line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/><line x1="4.93" y1="4.93" x2="6.34" y2="6.34"/><line x1="17.66" y1="17.66" x2="19.07" y2="19.07"/><line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/><line x1="4.93" y1="19.07" x2="6.34" y2="17.66"/><line x1="17.66" y1="6.34" x2="19.07" y2="4.93"/></svg>
          </button>
          <button class="nav-cta" onclick="document.getElementById('contact').scrollIntoView({behavior:'smooth'})" data-i18n="nav_cta">Contacto</button>
        </div>
      </div>
    </nav>

    <main class="page">
      <slot />
    </main>

    <footer class="foot">
      <div class="container foot-inner">
        <p>© 2024 — 2026 · Kevin Quiroz · Puebla, MX</p>
        <div class="foot-links">
          <a href="/privacidad">Privacidad</a>
          <a href="/condiciones">Términos</a>
          <a href="#hero">↑ Top</a>
        </div>
      </div>
    </footer>

    <!-- WhatsApp floating button -->
    <a href="https://wa.me/527351842906" target="_blank" rel="noopener" class="whatsapp-float" aria-label="WhatsApp">
      <svg width="28" height="28" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
    </a>

    <script is:inline>
      /* ════════════ NAV scroll state ════════════ */
      const nav = document.getElementById('nav');
      addEventListener('scroll', () => nav.classList.toggle('scrolled', scrollY > 30));

      /* ════════════ Cursor light ════════════ */
      const cl = document.getElementById('cursor-light');
      let cx = innerWidth/2, cy = innerHeight/2;
      let tx = cx, ty = cy;
      addEventListener('mousemove', (e) => { tx = e.clientX; ty = e.clientY; cl.style.opacity = '1'; });
      addEventListener('mouseleave', () => { cl.style.opacity = '0'; });
      function tickCursor(){
        cx += (tx - cx) * 0.12;
        cy += (ty - cy) * 0.12;
        cl.style.transform = `translate(${cx}px, ${cy}px) translate(-50%, -50%)`;
        requestAnimationFrame(tickCursor);
      }
      tickCursor();

      /* ════════════ Theme toggle ════════════ */
      (function(){
        const root = document.documentElement;
        const saved = localStorage.getItem('kq-theme');
        const sys = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        root.setAttribute('data-theme', saved || sys);
        const sun = document.getElementById('icon-sun');
        const moon = document.getElementById('icon-moon');
        function paint() {
          const t = root.getAttribute('data-theme');
          if (sun) sun.style.display = t === 'light' ? 'block' : 'none';
          if (moon) moon.style.display = t === 'light' ? 'none' : 'block';
        }
        paint();
        const btn = document.getElementById('theme-toggle');
        if (btn) btn.addEventListener('click', () => {
          const cur = root.getAttribute('data-theme') || 'dark';
          const nxt = cur === 'light' ? 'dark' : 'light';
          root.setAttribute('data-theme', nxt);
          localStorage.setItem('kq-theme', nxt);
          paint();
        });
        window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', (e) => {
          if (!localStorage.getItem('kq-theme')) {
            root.setAttribute('data-theme', e.matches ? 'light' : 'dark');
            paint();
          }
        });
      })();

      /* ════════════ Lang toggle ════════════ */
      window.currentLang = localStorage.getItem('kq-lang-cosmos') || 'es';

      const T = {
        es: {},
        en: {
          nav_about: "About", nav_services: "Services", nav_projects: "Work", nav_notes: "Notes", nav_cta: "Contact",
          hero_status: "Available · Q3 2026",
          hero_h1: "I automate",
          hero_h2: "your ecommerce.",
          hero_role: "Specialist in",
          hero_bio: "I automate CX and operations for ecommerce in LATAM. <strong>2+ years</strong> · <strong>68+ workflows</strong> · n8n + Chatwoot + Shopify. Based in Puebla, Mexico — remote worldwide.",
          cta_work: "See the work", cta_talk: "Let's talk",
          lbl_about: "About · 01",
          about_h: "Systems that <span class='grad'>don't fail.</span>",
          about_lead: "CX Operations &amp; Automation Specialist. I build the invisible plumbing that keeps ecommerce stores running when no one's watching.",
          about_p1: "Specialized in CX automation with <strong>n8n, Chatwoot and Shopify</strong>. I integrate APIs, webhooks and AI solutions so your customer support scales without scaling the team.",
          about_p2: "Two years, 68 workflows in production. The difference between a demo and an operation is what happens at 3 AM when a customer escalates and there's no support available. <strong>My job is making sure that doesn't happen.</strong>",
          ast_y: "Years", ast_w: "Workflows", ast_p: "Projects", ast_l: "English",
          now: "Now",
          present: "Present",
          j1b1: "Automate support operations via n8n, Chatwoot and AI",
          j1b2: "End-to-end CX workflow design and maintenance",
          j1b3: "Shopify, REST API and webhook integrations",
          j_free_t: "Freelance Automation Specialist",
          j_free_b1: "Jousfit: 68+ workflows — n8n · Chatwoot · Shopify · Supabase · OpenAI",
          j_free_b2: "Valt: marketing automation — Whisper · Mailchimp · Hotmart",
          j_free_b3: "n8n Bodas: CRM + scraping + email tracking for events",
          j_inside_t: "Business Development Specialist",
          j_inside_b1: "Commercial prospecting and lead generation",
          j2b1: "WordPress and React.js development: performance, UI/UX, responsiveness",
          j2b2: "Technical SEO plugin integration",
          j2b3: "Responsive layout implementation",
          edu: "B.Sc. Systems Engineering",
          lbl_srv: "Services · 02",
          srv_h: "What I <span class='grad'>build.</span>",
          svc1_t: "Automation",
          svc1_p: "n8n and Make. End-to-end ecommerce workflows with error handling, logs and production reliability.",
          svc2_t: "Chatbot & AI Support",
          svc2_p: "Chatwoot + OpenAI. Conversational agents with human handoff, automatic escalation and persistent context.",
          svc3_t: "API & Webhooks",
          svc3_p: "App-to-app connections, real-time sync and robust error handling.",
          svc4_t: "Shopify & Ecommerce",
          svc4_p: "Order automation, post-sale support and fraud detection. Shopify + Supabase + n8n.",
          svc5_t: "CX Operations",
          svc5_p: "Customer journey mapping, bottleneck removal and scalable support process design.",
          svc6_t: "AI Integration",
          svc6_p: "OpenAI, Whisper, generative pipelines. AI as support infrastructure, not a gimmick.",
          lbl_proj: "Projects · 03",
          proj_h: "<span class='grad'>7 things</span> that shipped.",
          p1d: "End-to-end event-management automation: scraping, email tracking and CRM sync. The planner went from \"I think we have 200 leads\" to a real, scored, dated list.",
          p2d: "Fitness ecommerce CRM: Chatwoot V0–V10, human buffer, Shopify fraud detection and conversational AI. Response time from 4 hours to 12 minutes.",
          p3d: "Marketing pipeline: Mailchimp, Hotmart, Whisper transcription and AI content. $0.12 per processed lesson.",
          p4d: "Website for a Kingston medical centre. Organic traffic +230% in four months.",
          p5d: "Corporate site for a consultancy. Time-on-site doubled, 3 inbound RFPs in 60 days.",
          p6d: "NFT landing with animations, wallet connect and generative design. Experimental Web3.",
          p7d: "WordPress plugin for smart redirection based on UTM params and user behavior. Zero bug reports in production, running on 6 client sites.",
          stack_h: "Tools of the <span class='grad'>craft.</span>",
          g_auto: "Automation", g_cx: "CX & Support", g_tools: "Tools",
          notes_h: "Technical <span class='grad'>notes.</span>",
          n1t: "Why n8n won the no-code war in production",
          n1e: "Real trade-offs between self-hosted n8n and Make when your workflow runs 24/7 with ecommerce at stake.",
          n2t: "Chatwoot + n8n: the support stack I use in production",
          n2e: "How to automate tickets, escalate to human and measure first response time in ecommerce.",
          n3t: "OpenAI inside n8n: architecture for reliable pipelines",
          n3e: "Retries, output validation, predictable costs with an LLM in the middle of the support flow.",
          lbl_con: "Contact · 06",
          contact_h: "Got an <span class='grad'>ecommerce</span> to automate?",
          contact_p: "CX automation for ecommerce, n8n integrations or AI support. I respond within 24h, in Spanish or English.",
          f_name: "Name", f_mail: "Email", f_msg: "Project",
          f_small: "REPLY IN < 24H", f_send: "Send"
        }
      };

      // Cache original ES text on first load
      document.querySelectorAll('[data-i18n]').forEach(el => {
        if (!el.dataset.es) el.dataset.es = el.innerHTML;
      });

      function setLang(lang){
        document.getElementById('lang-es').classList.toggle('active', lang === 'es');
        document.getElementById('lang-en').classList.toggle('active', lang === 'en');
        document.documentElement.lang = lang;
        document.querySelectorAll('[data-i18n]').forEach(el => {
          const key = el.getAttribute('data-i18n');
          if (lang === 'es') {
            el.innerHTML = el.dataset.es;
          } else if (T.en[key] !== undefined) {
            el.innerHTML = T.en[key];
          }
        });
        window.currentLang = lang;
        localStorage.setItem('kq-lang-cosmos', lang);
        document.dispatchEvent(new CustomEvent('langchange', { detail: { lang } }));
      }

      // Init lang
      const savedLang = localStorage.getItem('kq-lang-cosmos') || 'es';
      if (savedLang === 'en') {
        document.addEventListener('DOMContentLoaded', () => {
          // re-cache ES after DOM is ready
          document.querySelectorAll('[data-i18n]').forEach(el => {
            if (!el.dataset.es) el.dataset.es = el.innerHTML;
          });
          setLang('en');
        });
      }
    </script>
  </body>
</html>
