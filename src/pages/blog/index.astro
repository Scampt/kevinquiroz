---
import Layout from '../../layouts/Layout.astro';
import { getPublishedNotes, catTag } from '../../utils/notes';

// Fuente única: las notas vienen de src/content/blog/*.md (sin hardcode).
const notes = await getPublishedNotes();
const posts = notes.map((note, i) => ({
  id: String(i + 1).padStart(3, '0'),
  slug: note.slug,
  date: note.data.date,
  title: note.data.title,
  excerpt: note.data.description,
  category: note.data.category,
  tagClass: catTag[note.data.category] ?? 'tag',
  readTime: `${note.data.readTime} min`,
}));

// Filtros = categorías presentes en las notas (más "All" al frente).
const categories = ['All', ...Array.from(new Set(notes.map(n => n.data.category)))];
---

<Layout
  title="Notas técnicas — Kevin Quiroz"
  description="Notas técnicas sobre automatización, QA, integraciones y herramientas no-code por Kevin Quiroz."
>
  <!-- ===================== BLOG HEADER ===================== -->
  <section id="blog-top" class="hero-wrap px-7" style="min-height: 60vh; padding-top: 160px; padding-bottom: 60px;">
    <div class="max-w-[1200px] mx-auto w-full relative z-10">
      <div class="fade-in">
        <span class="kicker mb-6 block" data-i18n="blog_kicker">05 · Notas técnicas</span>
        <h1 class="hero-h1 mb-6" data-i18n="blog_h1" set:html="Notas <em class='accent'>técnicas.</em>"></h1>
        <p class="hero-bio max-w-[640px]" data-i18n="blog_intro">
          Apuntes de campo sobre automatización con n8n y Zapier, QA aplicado a workflows, integraciones con APIs y todo lo que aprendo metiendo IA en sistemas que tienen que correr de verdad.
        </p>
      </div>
    </div>
  </section>

  <!-- ===================== BLOG LIST ===================== -->
  <section class="px-7 pb-[120px]">
    <div class="max-w-[1200px] mx-auto">
      <!-- Category filter (visual only — purely declarative for now) -->
      <div class="fade-in flex flex-wrap gap-2 mb-10 pb-6 border-b border-[var(--kq-border)]">
        <span class="font-mono text-[10px] tracking-[0.18em] uppercase text-[var(--kq-muted)] self-center mr-2" data-i18n="blog_filter">FILTRAR</span>
        {categories.map((cat, i) => (
          <button
            class={`tag ${i === 0 ? 'tag-accent' : ''} cursor-pointer`}
            style="border-radius: 999px; padding: 6px 14px; font-size: 11px;"
            data-cat={cat}
            type="button"
          >
            <span class="swatch"></span>{cat}
          </button>
        ))}
      </div>

      <div class="blog-list fade-in">
        {posts.map(post => (
          <a href={`/notes/${post.slug}`} id={post.id} class="blog-row" data-cat={post.category}>
            <span class="col-num">{post.id}</span>
            <span class="col-date">{post.date}</span>
            <h3 class="col-title">
              <span>{post.title}</span>
              <span class="excerpt">{post.excerpt}</span>
              <span class="font-mono text-[10px] text-[var(--kq-muted2)] mt-2 inline-flex items-center gap-3" style="letter-spacing:.1em">
                <span>· {post.readTime} read</span>
              </span>
            </h3>
            <span class="col-tag"><span class={`tag ${post.tagClass}`}><span class="swatch"></span>{post.category}</span></span>
            <span class="col-arrow">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>

      <!-- Newsletter teaser -->
      <div class="fade-in mt-16 p-8 rounded-xl border border-[var(--kq-border)] bg-[var(--kq-surface)] grid md:grid-cols-[1fr_auto] gap-6 items-center">
        <div>
          <p class="font-mono text-[10px] tracking-[0.18em] uppercase text-[var(--kq-accent)] mb-2">SUBSCRIBE · 00</p>
          <h3 class="font-display text-[28px] m-0 mb-2" style="font-weight:400; letter-spacing: -0.01em;" data-i18n="newsletter_title">
            Notas en tu inbox, sin spam.
          </h3>
          <p class="text-[var(--kq-muted)] text-sm m-0 max-w-[460px]" data-i18n="newsletter_desc">
            Una o dos veces al mes. Solo cuando publico algo que vale la pena leer.
          </p>
        </div>
        <form class="flex gap-2 w-full md:w-auto" action="https://formspree.io/f/mayzpleg" method="POST">
          <input
            type="hidden"
            name="kind"
            value="newsletter"
          />
          <input
            type="email"
            name="email"
            required
            placeholder="tu@email.com"
            class="flex-1 md:w-[260px] px-4 py-3 rounded-lg bg-[var(--kq-bg)] border border-[var(--kq-border)] text-[var(--kq-text)] text-sm focus:outline-none focus:border-[var(--kq-accent)] transition-colors font-mono"
          />
          <button type="submit" class="btn btn-primary" data-i18n="newsletter_submit">
            Suscribirme
          </button>
        </form>
      </div>

      <!-- Back to home -->
      <div class="mt-16 pt-8 border-t border-[var(--kq-border)] flex items-center justify-between gap-4 flex-wrap">
        <a href="/" class="font-mono text-[12px] text-[var(--kq-muted)] hover:text-[var(--kq-accent)] transition-colors">
          ← <span data-i18n="back_home">Volver al inicio</span>
        </a>
        <span class="font-mono text-[11px] text-[var(--kq-muted2)] tracking-wider">
          {posts.length} <span data-i18n="blog_count_label">notas publicadas</span> · <span data-i18n="more_coming">más por venir</span>
        </span>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  // ─── Translations specific to the blog index ─────────────────
  const tBlog = {
    es: {
      blog_kicker: "05 · Notas técnicas",
      blog_h1: "Notas <em class='accent'>técnicas.</em>",
      blog_intro: "Apuntes de campo sobre automatización con n8n y Zapier, QA aplicado a workflows, integraciones con APIs y todo lo que aprendo metiendo IA en sistemas que tienen que correr de verdad.",
      blog_filter: "FILTRAR",
      blog_soon: "Próximamente · más notas en camino",
      newsletter_title: "Notas en tu inbox, sin spam.",
      newsletter_desc: "Una o dos veces al mes. Solo cuando publico algo que vale la pena leer.",
      newsletter_submit: "Suscribirme",
      back_home: "Volver al inicio",
      blog_count_label: "notas publicadas",
      more_coming: "más por venir"
    },
    en: {
      blog_kicker: "05 · Technical notes",
      blog_h1: "Technical <em class='accent'>notes.</em>",
      blog_intro: "Field notes on automation with n8n and Zapier, QA applied to workflows, API integrations and everything I learn putting AI inside systems that actually need to run.",
      blog_filter: "FILTER",
      blog_soon: "Coming soon · more notes on the way",
      newsletter_title: "Notes in your inbox, no spam.",
      newsletter_desc: "Once or twice a month. Only when I publish something worth reading.",
      newsletter_submit: "Subscribe",
      back_home: "Back to home",
      blog_count_label: "notes published",
      more_coming: "more coming"
    }
  };
  const HTML_KEYS_BLOG = new Set(['blog_h1']);

  // Las notas son contenido en español (la página /notes/<slug> es ES).
  // El toggle de idioma solo traduce el "chrome" del archivo (encabezado,
  // intro, newsletter); los títulos/excerpts se quedan en ES.
  function applyBlogLang(lang) {
    const dict = tBlog[lang] || tBlog.es;
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      if (!dict[key]) return;
      if (HTML_KEYS_BLOG.has(key)) el.innerHTML = dict[key];
      else el.textContent = dict[key];
    });
  }

  document.addEventListener('DOMContentLoaded', () => applyBlogLang(window.currentLang || 'es'));
  document.addEventListener('langchange', (e) => applyBlogLang(e.detail.lang));

  // ─── Fade-in observer ─────────────────────────────────────────
  (function(){
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
      });
    }, { threshold: 0.12 });
    document.querySelectorAll('.fade-in').forEach(el => obs.observe(el));
  })();

  // ─── Category filter (client-side) ────────────────────────────
  (function(){
    const buttons = document.querySelectorAll('button[data-cat]');
    const rows = document.querySelectorAll('.blog-row[data-cat]');
    buttons.forEach(b => {
      b.addEventListener('click', () => {
        const cat = b.getAttribute('data-cat');
        buttons.forEach(x => x.classList.toggle('tag-accent', x === b));
        rows.forEach(r => {
          const match = cat === 'All' || r.getAttribute('data-cat') === cat;
          r.style.display = match ? '' : 'none';
        });
      });
    });
  })();
</script>
