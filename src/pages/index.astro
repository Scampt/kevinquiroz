---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- ═══════════════════ HERO ═══════════════════ -->
  <section id="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-left reveal">
          <div class="hero-status">
            <span class="dot"></span>
            <span data-i18n="hero_status">Disponible · Q3 2026</span>
          </div>
          <h1>
            <span data-i18n="hero_h1">Workflows</span><br />
            <span class="gradient" data-i18n="hero_h2">que no se rompen</span>
          </h1>
          <div class="hero-role">
            <span data-i18n="hero_role">Especialista en</span>
            <span class="chip">n8n</span>
            <span class="chip">Zapier</span>
            <span class="chip">OpenAI</span>
          </div>
          <p class="hero-bio" data-i18n="hero_bio">
            Diseño, testeo y mantengo workflows complejos e integraciones que corren en producción 24/7. <strong>3+ años</strong> · <strong>50+ workflows</strong> · <strong>0 incidentes P0</strong> este trimestre. Desde Morelos, México — remoto worldwide.
          </p>
          <div class="hero-cta-row">
            <button class="btn btn-primary" onclick="document.getElementById('projects').scrollIntoView({behavior:'smooth'})">
              <span data-i18n="cta_work">Ver el trabajo</span>
              <span class="arr">↗</span>
            </button>
            <button class="btn btn-ghost" onclick="document.getElementById('contact').scrollIntoView({behavior:'smooth'})">
              <span data-i18n="cta_talk">Hablemos</span>
            </button>
          </div>
        </div>

        <div class="hero-right reveal">
          <div class="orb iris hero-orb" id="hero-orb">
            <div class="orb-halo"></div>
            <div class="orb-sphere"></div>
          </div>
          <div class="hero-photo">
            <img src="/me.jpg" alt="Kevin Quiroz" />
            <div class="caption">KQ · MX</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ ABOUT ═══════════════════ -->
  <section id="about" class="s">
    <div class="container">
      <div class="s-head reveal">
        <span class="label" data-i18n="lbl_about">Sobre mí · 01</span>
        <h2 data-i18n="about_h">Sistemas que <span class="grad">no fallan.</span></h2>
      </div>

      <div class="about-grid">
        <div class="about-photo-wrap reveal">
          <img src="/me.jpg" alt="Kevin Quiroz" />
          <div class="about-photo-meta">
            <div class="name">Luis Kevin Quiroz Pacheco</div>
            <div class="where">Morelos, México</div>
          </div>
        </div>

        <div class="about-prose reveal">
          <p class="lead" data-i18n="about_lead">
            No-Code Automation Specialist <span class="grad">&amp;</span> QA Analyst. Diseño la fontanería invisible que mantiene a los negocios corriendo cuando nadie está mirando.
          </p>
          <p data-i18n="about_p1">
            Especializado en automatizaciones con <strong>Zapier, Make y n8n</strong>, integración de APIs y webhooks, y soluciones con IA usando OpenAI. Background sólido en análisis de requerimientos, planificación de pruebas, testing de regresión y seguimiento de incidencias.
          </p>
          <p data-i18n="about_p2">
            Tres años, cincuenta workflows en producción, cero incidentes P0 este trimestre. La diferencia entre un demo y una operación es lo que pasa a las 3 AM cuando una API cambia. <strong>Mi trabajo es que sigas durmiendo.</strong>
          </p>

          <div class="about-stats">
            <div class="glass-card"><div class="n">3+</div><div class="l" data-i18n="ast_y">Años</div></div>
            <div class="glass-card"><div class="n">50+</div><div class="l" data-i18n="ast_w">Workflows</div></div>
            <div class="glass-card"><div class="n">07</div><div class="l" data-i18n="ast_p">Proyectos</div></div>
            <div class="glass-card"><div class="n">03</div><div class="l" data-i18n="ast_l">Idiomas</div></div>
          </div>

          <div class="timeline">
            <div class="tl">
              <div class="when">Oct 2025<br /><span class="now" data-i18n="now">Now</span></div>
              <div>
                <h4>CX Operations &amp; Automation Specialist</h4>
                <div class="org hl">Interprika</div>
                <ul>
                  <li data-i18n="j1b1">Automatizaciones CRM + marketing vía Zapier, Make, n8n</li>
                  <li data-i18n="j1b2">Análisis de requerimientos → user stories en Trello</li>
                  <li data-i18n="j1b3">Casos de prueba manuales y automatizados</li>
                </ul>
              </div>
            </div>
            <div class="tl">
              <div class="when">Nov 2024 — Apr 2025</div>
              <div>
                <h4>Frontend Developer</h4>
                <div class="org">Bedrock Digital</div>
                <ul>
                  <li data-i18n="j2b1">QA WordPress y React.js: performance, UI/UX, responsividad</li>
                  <li data-i18n="j2b2">Integración de plugins SEO técnico</li>
                  <li data-i18n="j2b3">Validación de layouts responsive</li>
                </ul>
              </div>
            </div>
            <div class="tl">
              <div class="when">2019 — 2024</div>
              <div>
                <h4 data-i18n="edu">Lic. Ciencias Computacionales</h4>
                <div class="org">BUAP — Benemérita Universidad Autónoma de Puebla</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ SERVICES ═══════════════════ -->
  <section id="services" class="s">
    <div class="container">
      <div class="s-head reveal">
        <span class="label" data-i18n="lbl_srv">Servicios · 02</span>
        <h2 data-i18n="srv_h">Lo que <span class="grad">construyo.</span></h2>
      </div>

      <div class="services">
        <article class="svc reveal">
          <div class="svc-glyph fire float float-1">
            <div class="surface">
              <svg class="icon" viewBox="0 0 24 24">
                <circle cx="5" cy="5.5" r="2"/>
                <circle cx="13" cy="5.5" r="2"/>
                <circle cx="11" cy="18.5" r="2"/>
                <circle cx="19" cy="18.5" r="2"/>
                <path d="M7 5.5h4"/>
                <path d="M13 7.5v5a2 2 0 0 1-2 2"/>
                <path d="M13 18.5h4"/>
              </svg>
            </div>
          </div>
          <h3 data-i18n="svc1_t">Automatización</h3>
          <p data-i18n="svc1_p">n8n, Zapier, Make. Workflows end-to-end con error handling, logs y confiabilidad de producción.</p>
          <div class="tags"><span class="tag">n8n</span><span class="tag">Zapier</span><span class="tag">Make</span></div>
        </article>

        <article class="svc reveal">
          <div class="svc-glyph aqua float float-2">
            <div class="surface">
              <svg class="icon" viewBox="0 0 24 24">
                <path d="M12 2.5 L4 5.5 v6 c0 4.8 3.4 8.4 8 10 c4.6-1.6 8-5.2 8-10 V5.5 z"/>
                <path d="M8.5 12 l2.5 2.5 l4.5-5"/>
              </svg>
            </div>
          </div>
          <h3 data-i18n="svc2_t">QA &amp; Testing</h3>
          <p data-i18n="svc2_p">Testing manual, regresión, smoke y edge-cases. Bug tracking y matrices completas.</p>
          <div class="tags"><span class="tag">Manual</span><span class="tag">Regression</span><span class="tag">Playwright</span></div>
        </article>

        <article class="svc reveal">
          <div class="svc-glyph violet float float-3">
            <div class="surface">
              <svg class="icon" viewBox="0 0 24 24">
                <path d="M3.5 9 H17 m-3-3 l3 3 -3 3"/>
                <path d="M20.5 15 H7 m3 3 l-3-3 3-3"/>
              </svg>
            </div>
          </div>
          <h3 data-i18n="svc3_t">API &amp; Webhooks</h3>
          <p data-i18n="svc3_p">Conexión entre apps, sincronización en tiempo real y manejo robusto de errores.</p>
          <div class="tags"><span class="tag">REST</span><span class="tag">Webhooks</span><span class="tag">JSON</span></div>
        </article>

        <article class="svc reveal">
          <div class="svc-glyph lime float float-4">
            <div class="surface">
              <svg class="icon" viewBox="0 0 24 24">
                <path d="M8 7.5 L2.5 12 L8 16.5"/>
                <path d="M16 7.5 L21.5 12 L16 16.5"/>
                <path d="M14 4.5 L10 19.5"/>
              </svg>
            </div>
          </div>
          <h3 data-i18n="svc4_t">Frontend Dev</h3>
          <p data-i18n="svc4_p">React, WordPress, Shopify. Performance-first con SEO técnico desde el inicio.</p>
          <div class="tags"><span class="tag">React</span><span class="tag">WordPress</span><span class="tag">Shopify</span></div>
        </article>

        <article class="svc reveal">
          <div class="svc-glyph sun float float-5">
            <div class="surface">
              <svg class="icon" viewBox="0 0 24 24">
                <path d="M3 18 C 6 18, 7 5, 12 5 C 17 5, 18 18, 21 18"/>
                <circle class="fill" cx="3" cy="18" r="1.8" stroke="none"/>
                <circle class="fill" cx="12" cy="5"  r="1.8" stroke="none"/>
                <circle class="fill" cx="21" cy="18" r="1.8" stroke="none"/>
                <circle class="fill" cx="7"  cy="12" r="1.2" stroke="none" opacity="0.75"/>
                <circle class="fill" cx="17" cy="12" r="1.2" stroke="none" opacity="0.75"/>
              </svg>
            </div>
          </div>
          <h3 data-i18n="svc5_t">CX Operations</h3>
          <p data-i18n="svc5_p">Customer journey mapping, eliminación de cuellos de botella, procesos escalables.</p>
          <div class="tags"><span class="tag">Journey</span><span class="tag">Processes</span></div>
        </article>

        <article class="svc reveal">
          <div class="svc-glyph iris float">
            <div class="surface">
              <svg class="icon" viewBox="0 0 24 24">
                <path class="fill" stroke="none" d="M12 2.5 L13.5 10.5 L21.5 12 L13.5 13.5 L12 21.5 L10.5 13.5 L2.5 12 L10.5 10.5 Z"/>
                <circle class="fill" cx="19.5" cy="4.5" r="1.1" stroke="none"/>
                <circle class="fill" cx="4.5"  cy="19.5" r="1.1" stroke="none"/>
                <circle class="fill" cx="19.5" cy="19.5" r="0.7" stroke="none" opacity="0.7"/>
              </svg>
            </div>
          </div>
          <h3 data-i18n="svc6_t">AI Integration</h3>
          <p data-i18n="svc6_p">OpenAI, Whisper, pipelines generativos. IA como infraestructura, no como gimmick.</p>
          <div class="tags"><span class="tag">OpenAI</span><span class="tag">Whisper</span><span class="tag">LLM</span></div>
        </article>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ PROJECTS ═══════════════════ -->
  <section id="projects" class="s">
    <div class="container">
      <div class="s-head reveal">
        <span class="label" data-i18n="lbl_proj">Proyectos · 03</span>
        <h2 data-i18n="proj_h"><span class="grad">7 cosas</span> que se enviaron.</h2>
      </div>

      <div class="projects">
        <article class="proj feature reveal">
          <div class="proj-top">
            <div class="proj-orb"><div class="surface"><svg viewBox="0 0 24 24"><circle cx="6" cy="6" r="1.7"/><circle cx="18" cy="6" r="1.7"/><circle cx="12" cy="18" r="1.7"/><path d="M7.7 7 L10.7 16.5"/><path d="M16.3 7 L13.3 16.5"/><path d="M8 6h8"/></svg></div></div>
            <div class="proj-actions"><a href="https://github.com/scampt/n8n-bodas" target="_blank" rel="noopener" aria-label="GitHub"><svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg></a></div>
          </div>
          <span class="proj-num">01 · 2024</span>
          <h3>n8n Bodas</h3>
          <p data-i18n="p1d">Automatización completa para gestión de eventos: scraping, email tracking y CRM sync. La planner pasó de "creo que tengo 200 leads" a una lista real, dateada y scoreada.</p>
          <div class="tags"><span class="tag hot">n8n</span><span class="tag">Scraping</span><span class="tag">CRM</span></div>
        </article>

        <article class="proj feature reveal">
          <div class="proj-top">
            <div class="proj-orb"><div class="surface"><svg viewBox="0 0 24 24"><path d="M4 5 h16 a1 1 0 0 1 1 1 v9 a1 1 0 0 1 -1 1 h-9 l-4 4 v-4 h-3 a1 1 0 0 1 -1 -1 v-9 a1 1 0 0 1 1 -1z"/><circle class="fill" cx="9" cy="10.5" r="1" stroke="none"/><circle class="fill" cx="12" cy="10.5" r="1" stroke="none"/><circle class="fill" cx="15" cy="10.5" r="1" stroke="none"/></svg></div></div>
            <div class="proj-actions"><a href="https://github.com/scampt/n8n-jousfit" target="_blank" rel="noopener" aria-label="GitHub"><svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg></a></div>
          </div>
          <span class="proj-num">02 · 2024–25</span>
          <h3>n8n JousFit</h3>
          <p data-i18n="p2d">Fitness CRM: Chatwoot V0–V10, buffer humano, detección de fraude Shopify e IA conversacional. Tiempo de respuesta de 4 horas a 12 minutos.</p>
          <div class="tags"><span class="tag hot">n8n</span><span class="tag hot">OpenAI</span><span class="tag">Shopify</span></div>
        </article>

        <article class="proj reveal">
          <div class="proj-top">
            <div class="proj-orb"><div class="surface"><svg viewBox="0 0 24 24"><path d="M5 11 V13"/><path d="M8 9 V15"/><path d="M11 6 V18"/><path d="M14 8 V16"/><path d="M17 4 V20"/><path d="M20 10 V14"/></svg></div></div>
            <div class="proj-actions"><a href="https://github.com/scampt/n8n-valt" target="_blank" rel="noopener" aria-label="GitHub"><svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg></a></div>
          </div>
          <span class="proj-num">03 · 2025</span>
          <h3>n8n Valt</h3>
          <p data-i18n="p3d">Marketing pipeline: Mailchimp, Hotmart, Whisper transcription y contenido con IA. $0.12 por lección.</p>
          <div class="tags"><span class="tag hot">n8n</span><span class="tag">Whisper</span></div>
        </article>

        <article class="proj reveal">
          <div class="proj-top">
            <div class="proj-orb"><div class="surface"><svg viewBox="0 0 24 24"><path d="M12 5 V19"/><path d="M5 12 H19"/></svg></div></div>
            <div class="proj-actions"><a href="https://ahfmedicalcentre.org.jm/" target="_blank" rel="noopener" aria-label="Live"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg></a></div>
          </div>
          <span class="proj-num">04 · 2025</span>
          <h3>AHF Jamaica</h3>
          <p data-i18n="p4d">Sitio web para centro médico en Kingston. Tráfico orgánico +230% en cuatro meses.</p>
          <div class="tags"><span class="tag">WordPress</span><span class="tag">SEO</span></div>
        </article>

        <article class="proj reveal">
          <div class="proj-top">
            <div class="proj-orb"><div class="surface"><svg viewBox="0 0 24 24"><path d="M5 18 V14"/><path d="M11 18 V10"/><path d="M17 18 V6"/><path d="M3 18 H21"/></svg></div></div>
            <div class="proj-actions"><a href="https://paragonisg.com/" target="_blank" rel="noopener" aria-label="Live"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg></a></div>
          </div>
          <span class="proj-num">05 · 2025</span>
          <h3>Paragon ISG</h3>
          <p data-i18n="p5d">Sitio corporativo para consultora. Time-on-site duplicado, 3 inbound RFPs en 60 días.</p>
          <div class="tags"><span class="tag">WordPress</span><span class="tag">Corporate</span></div>
        </article>

        <article class="proj reveal">
          <div class="proj-top">
            <div class="proj-orb"><div class="surface"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="4"/><ellipse cx="12" cy="12" rx="9" ry="2.5" transform="rotate(-15 12 12)"/></svg></div></div>
            <div class="proj-actions">
              <a href="https://scampt.github.io/LutherAlien/" target="_blank" rel="noopener" aria-label="Live"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg></a>
              <a href="https://github.com/scampt/LutherAlien" target="_blank" rel="noopener" aria-label="GitHub"><svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg></a>
            </div>
          </div>
          <span class="proj-num">06 · 2023</span>
          <h3>LutherAlien</h3>
          <p data-i18n="p6d">NFT landing con animaciones, wallet connect y diseño generativo. Web3 experimental.</p>
          <div class="tags"><span class="tag">NFT</span><span class="tag">Web3</span></div>
        </article>

        <article class="proj wide reveal">
