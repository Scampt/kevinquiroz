---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- ===================== HERO ===================== -->
  <section id="hero" class="min-h-screen flex items-center pt-20 pb-12 px-6">
    <div class="max-w-6xl mx-auto w-full">
      <div class="fade-in">
        <!-- Status badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-[rgba(0,255,136,0.2)] bg-[rgba(0,255,136,0.05)] mb-8">
          <span class="w-2 h-2 rounded-full bg-[#00ff88] animate-pulse"></span>
          <span class="font-mono text-xs text-[#00ff88]" data-i18n="hero_status">Disponible para proyectos</span>
        </div>

        <!-- Name -->
        <h1 class="text-5xl md:text-7xl font-bold mb-4 leading-tight">
          Kevin<br />
          <span class="gradient-text">Quiroz</span>
        </h1>

        <!-- Typewriter role -->
        <div class="flex items-center gap-2 mb-6">
          <span class="text-[var(--kq-muted2)] font-mono text-lg">&gt;</span>
          <span id="typewriter-text" class="text-xl md:text-2xl font-mono text-[var(--kq-text)]"></span>
          <span class="typewriter-cursor"></span>
        </div>

        <!-- Bio -->
        <p id="hero-bio" class="text-[var(--kq-muted)] max-w-2xl text-base md:text-lg mb-8 leading-relaxed">
          No-Code Automation Specialist &amp; QA Analyst. Diseño, testeo y mantengo workflows
          complejos e integraciones. Especializado en n8n, Zapier, Make y OpenAI.
          Morelos, México.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4 mb-10">
          <a
            href="#projects"
            id="cta-projects"
            class="px-6 py-3 rounded-lg bg-[#00ff88] text-[#0a0a0f] font-semibold text-sm hover:bg-white transition-colors"
            data-i18n="cta_projects"
          >
            Ver Proyectos
          </a>
          <a
            href="#contact"
            id="cta-contact"
            class="px-6 py-3 rounded-lg border border-[rgba(255,255,255,0.12)] text-[var(--kq-text)] font-semibold text-sm hover:border-[#00ff88] hover:text-[#00ff88] transition-all"
            data-i18n="cta_contact"
          >
            Contáctame
          </a>
        </div>

        <!-- Social links -->
        <div class="flex items-center gap-6">
          <a href="https://github.com/scampt" target="_blank" rel="noopener" class="text-[var(--kq-muted)] hover:text-[var(--kq-text)] transition-colors" aria-label="GitHub">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
          <a href="https://www.linkedin.com/in/kevinquirozmx/" target="_blank" rel="noopener" class="text-[var(--kq-muted)] hover:text-[#00c9ff] transition-colors" aria-label="LinkedIn">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://twitter.com/KevinQuirozMX" target="_blank" rel="noopener" class="text-[var(--kq-muted)] hover:text-[var(--kq-text)] transition-colors" aria-label="Twitter/X">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.747l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://www.instagram.com/kevinquirozmx/" target="_blank" rel="noopener" class="text-[var(--kq-muted)] hover:text-[var(--kq-text)] transition-colors" aria-label="Instagram">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
          </a>
          <a href="mailto:luis.kevin.quiroz@gmail.com" class="text-[var(--kq-muted)] hover:text-[#00ff88] transition-colors font-mono text-xs" aria-label="Email">
            luis.kevin.quiroz@gmail.com
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== ABOUT ===================== -->
  <section id="about" class="py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="fade-in mb-12">
        <span class="section-label" data-i18n="section_about">SOBRE MÍ</span>
        <h2 class="text-3xl md:text-4xl font-bold mt-2">
          <span data-i18n="about_title">Construyo sistemas que no fallan.</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-start">
        <!-- Text + Photo -->
        <div class="fade-in">
          <div class="flex items-start gap-4 mb-6">
            <img
              src="/avatar.png"
              alt="Kevin Quiroz"
              class="w-16 h-16 rounded-full object-cover border-2 border-[rgba(0,255,136,0.3)]"
            />
            <div>
              <p class="font-semibold text-[var(--kq-text)]">Luis Kevin Quiroz Pacheco</p>
              <p class="text-sm text-[var(--kq-muted2)] font-mono">@scampt · Morelos, México</p>
            </div>
          </div>
          <p id="about-text" class="text-[var(--kq-muted)] leading-relaxed mb-6">
            No-Code Automation Specialist &amp; QA Analyst con experiencia práctica diseñando,
            testeando y manteniendo workflows complejos e integraciones. Especializado en
            automatizaciones con Zapier, Make y n8n, conexión de APIs y webhooks, e implementación
            de soluciones con IA usando OpenAI. Background sólido en análisis de requerimientos,
            planificación de pruebas, testing de regresión y seguimiento de incidencias.
          </p>

          <!-- Quick facts -->
          <div class="grid grid-cols-2 gap-4">
            <div class="p-4 rounded-lg border border-[var(--kq-border)] bg-[var(--kq-surface)]">
              <p class="font-mono text-[#00ff88] text-lg font-bold">3+</p>
              <p class="text-[var(--kq-muted2)] text-sm" data-i18n="fact_years">años de experiencia</p>
            </div>
            <div class="p-4 rounded-lg border border-[var(--kq-border)] bg-[var(--kq-surface)]">
              <p class="font-mono text-[#00c9ff] text-lg font-bold">50+</p>
              <p class="text-[var(--kq-muted2)] text-sm" data-i18n="fact_workflows">workflows en producción</p>
            </div>
            <div class="p-4 rounded-lg border border-[var(--kq-border)] bg-[var(--kq-surface)]">
              <p class="font-mono text-[#00ff88] text-lg font-bold">7</p>
              <p class="text-[var(--kq-muted2)] text-sm" data-i18n="fact_projects">proyectos destacados</p>
            </div>
            <div class="p-4 rounded-lg border border-[var(--kq-border)] bg-[var(--kq-surface)]">
              <p class="font-mono text-[#00c9ff] text-lg font-bold">3</p>
              <p class="text-[var(--kq-muted2)] text-sm" data-i18n="fact_langs">idiomas</p>
            </div>
          </div>
        </div>

        <!-- Experience Timeline -->
        <div class="fade-in">
          <span class="section-label mb-6 block" data-i18n="section_experience">EXPERIENCIA</span>

          <div class="space-y-8">
            <!-- Job 1 -->
            <div class="relative pl-6">
              <div class="timeline-line"></div>
              <div class="absolute left-0 top-2.5 w-3.5 h-3.5 rounded-full border-2 border-[#00ff88] bg-[var(--kq-bg)]"></div>
              <div class="p-4 rounded-lg border border-[var(--kq-border)] bg-[var(--kq-surface)] card-glow">
                <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
                  <div>
                    <p class="font-semibold text-[var(--kq-text)] text-sm">CX Operations &amp; Automation Specialist</p>
                    <p class="text-[#00ff88] text-xs font-mono">Interprika</p>
                  </div>
                  <span class="tag tag-green text-xs">Oct 2025 – Presente</span>
                </div>
                <ul class="text-[var(--kq-muted2)] text-xs space-y-1 list-none">
                  <li>· Automatizaciones CRM + marketing via Zapier, Make, n8n</li>
                  <li>· Análisis de requerimientos → user stories en Trello</li>
                  <li>· Casos de prueba manuales y automatizados</li>
                  <li>· Documentación de workflows y manuales</li>
                </ul>
              </div>
            </div>

            <!-- Job 2 -->
            <div class="relative pl-6">
              <div class="absolute left-0 top-2.5 w-3.5 h-3.5 rounded-full border-2 border-[#00c9ff] bg-[var(--kq-bg)]"></div>
              <div class="p-4 rounded-lg border border-[var(--kq-border)] bg-[var(--kq-surface)] card-glow">
                <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
                  <div>
                    <p class="font-semibold text-[var(--kq-text)] text-sm">Frontend Developer</p>
                    <p class="text-[#00c9ff] text-xs font-mono">Bedrock Digital</p>
                  </div>
                  <span class="tag tag-blue text-xs">Nov 2024 – Abr 2025</span>
                </div>
                <ul class="text-[var(--kq-muted2)] text-xs space-y-1">
                  <li>· QA WordPress y React.js: performance, UI/UX, responsividad</li>
                  <li>· Integración de plugins SEO</li>
                  <li>· Validación de layouts responsive</li>
                  <li>· GitHub para issue tracking y code reviews</li>
                </ul>
              </div>
            </div>

            <!-- Education -->
            <div class="relative pl-6">
              <div class="absolute left-0 top-2.5 w-3.5 h-3.5 rounded-full border-2 border-[#666] bg-[var(--kq-bg)]"></div>
              <div class="p-4 rounded-lg border border-[var(--kq-border)] bg-[var(--kq-surface)]">
                <div class="flex flex-wrap items-start justify-between gap-2 mb-1">
                  <div>
                    <p class="font-semibold text-[var(--kq-text)] text-sm" data-i18n="edu_degree">Lic. Ciencias Computacionales</p>
                    <p class="text-[var(--kq-muted2)] text-xs font-mono">BUAP — Benemérita Universidad Autónoma de Puebla</p>
                  </div>
                  <span class="tag tag-gray text-xs">2019–2024</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Languages -->
          <div class="mt-8 p-4 rounded-lg border border-[var(--kq-border)] bg-[var(--kq-surface)]">
            <p class="text-[var(--kq-muted2)] text-xs font-mono mb-3 uppercase tracking-widest" data-i18n="label_languages">Idiomas</p>
            <div class="flex flex-wrap gap-2">
              <span class="tag tag-green">Español C2</span>
              <span class="tag tag-blue">English B1</span>
              <span class="tag tag-gray">Français A1</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== SERVICES ===================== -->
  <section id="services" class="py-20 px-6 section-dim">
    <div class="max-w-6xl mx-auto">
      <div class="fade-in mb-12">
        <span class="section-label" data-i18n="section_services">SERVICIOS</span>
        <h2 class="text-3xl md:text-4xl font-bold mt-2" data-i18n="services_title">Lo que construyo.</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 fade-in-stagger">
        <!-- 1 -->
        <div class="p-6 rounded-xl border border-[var(--kq-border)] bg-[var(--kq-surface)] card-glow">
          <div class="w-10 h-10 rounded-lg bg-[rgba(0,255,136,0.1)] flex items-center justify-center mb-4">
            <svg width="20" height="20" fill="none" stroke="#00ff88" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 0 0 0-4.5H6v4.5Zm0 0H3.75m2.25 0v4.5m0-4.5h6.75m-6.75 4.5H3.75M6 15h2.25a2.25 2.25 0 0 1 0 4.5H6V15Z"/></svg>
          </div>
          <h3 class="font-semibold text-[var(--kq-text)] mb-2" data-i18n="svc1_title">No-Code Automation</h3>
          <p class="text-[var(--kq-muted2)] text-sm leading-relaxed" data-i18n="svc1_desc">n8n, Zapier, Make. Workflows end-to-end con error handling, logs y confiabilidad de producción.</p>
          <div class="flex flex-wrap gap-1.5 mt-4">
            <span class="tag tag-green">n8n</span>
            <span class="tag tag-green">Zapier</span>
            <span class="tag tag-green">Make</span>
          </div>
        </div>

        <!-- 2 -->
        <div class="p-6 rounded-xl border border-[var(--kq-border)] bg-[var(--kq-surface)] card-glow">
          <div class="w-10 h-10 rounded-lg bg-[rgba(0,201,255,0.1)] flex items-center justify-center mb-4">
            <svg width="20" height="20" fill="none" stroke="#00c9ff" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z"/></svg>
          </div>
          <h3 class="font-semibold text-[var(--kq-text)] mb-2" data-i18n="svc2_title">QA &amp; Testing</h3>
          <p class="text-[var(--kq-muted2)] text-sm leading-relaxed" data-i18n="svc2_desc">Testing manual, regresión, smoke y edge-cases. Bug tracking y matrices de prueba completas.</p>
          <div class="flex flex-wrap gap-1.5 mt-4">
            <span class="tag tag-blue">Manual</span>
            <span class="tag tag-blue">Regression</span>
            <span class="tag tag-blue">Playwright</span>
          </div>
        </div>

        <!-- 3 -->
        <div class="p-6 rounded-xl border border-[var(--kq-border)] bg-[var(--kq-surface)] card-glow">
          <div class="w-10 h-10 rounded-lg bg-[rgba(168,85,247,0.1)] flex items-center justify-center mb-4">
            <svg width="20" height="20" fill="none" stroke="#a855f7" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"/></svg>
          </div>
          <h3 class="font-semibold text-[var(--kq-text)] mb-2" data-i18n="svc3_title">API &amp; Webhook Integration</h3>
          <p class="text-[var(--kq-muted2)] text-sm leading-relaxed" data-i18n="svc3_desc">Conexión entre apps, sincronización de datos en tiempo real y manejo robusto de errores.</p>
          <div class="flex flex-wrap gap-1.5 mt-4">
            <span class="tag tag-purple">REST</span>
            <span class="tag tag-purple">Webhooks</span>
            <span class="tag tag-purple">JSON</span>
          </div>
        </div>

        <!-- 4 -->
        <div class="p-6 rounded-xl border border-[var(--kq-border)] bg-[var(--kq-surface)] card-glow">
          <div class="w-10 h-10 rounded-lg bg-[rgba(234,179,8,0.1)] flex items-center justify-center mb-4">
            <svg width="20" height="20" fill="none" stroke="#eab308" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5"/></svg>
          </div>
          <h3 class="font-semibold text-[var(--kq-text)] mb-2" data-i18n="svc4_title">Frontend Development</h3>
          <p class="text-[var(--kq-muted2)] text-sm leading-relaxed" data-i18n="svc4_desc">React, WordPress, Shopify. Performance-first con SEO técnico integrado desde el inicio.</p>
          <div class="flex flex-wrap gap-1.5 mt-4">
            <span class="tag tag-yellow">React</span>
            <span class="tag tag-yellow">WordPress</span>
            <span class="tag tag-yellow">Shopify</span>
          </div>
        </div>

        <!-- 5 -->
        <div class="p-6 rounded-xl border border-[var(--kq-border)] bg-[var(--kq-surface)] card-glow">
          <div class="w-10 h-10 rounded-lg bg-[rgba(249,115,22,0.1)] flex items-center justify-center mb-4">
            <svg width="20" height="20" fill="none" stroke="#f97316" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/></svg>
          </div>
          <h3 class="font-semibold text-[var(--kq-text)] mb-2" data-i18n="svc5_title">CX Operations</h3>
          <p class="text-[var(--kq-muted2)] text-sm leading-relaxed" data-i18n="svc5_desc">Customer journey mapping, eliminación de cuellos de botella, diseño de procesos escalables.</p>
          <div class="flex flex-wrap gap-1.5 mt-4">
            <span class="tag tag-orange">Journey Map</span>
            <span class="tag tag-orange">Processes</span>
          </div>
        </div>

        <!-- 6 -->
        <div class="p-6 rounded-xl border border-[var(--kq-border)] bg-[var(--kq-surface)] card-glow">
          <div class="w-10 h-10 rounded-lg bg-[rgba(0,255,136,0.1)] flex items-center justify-center mb-4">
