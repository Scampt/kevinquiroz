@media (max-width: 480px) {
  .ms-opts { grid-template-columns: 1fr; }
}
</style>

<script is:inline>
  /* ════════════ Hero orb follows cursor ════════════ */
  (function(){
    const orb = document.getElementById('hero-orb');
    if (!orb) return;
    let mx = innerWidth/2, my = innerHeight/2;
    let cx = mx, cy = my;
    addEventListener('mousemove', (e) => { mx = e.clientX; my = e.clientY; });
    function tick(){
      cx += (mx - cx) * 0.045;
      cy += (my - cy) * 0.045;
      const r = orb.parentElement.getBoundingClientRect();
      const ax = (cx - (r.left + r.width/2)) / r.width;
      const ay = (cy - (r.top  + r.height/2)) / r.height;
      const tx = Math.max(-0.7, Math.min(0.7, ax)) * 50;
      const ty = Math.max(-0.7, Math.min(0.7, ay)) * 50;
      orb.style.transform = `translate(${tx}px, ${ty}px)`;
      requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  })();

  /* ════════════ Service card cursor track ════════════ */
  document.querySelectorAll('.svc').forEach(card => {
    card.addEventListener('mousemove', (e) => {
      const r = card.getBoundingClientRect();
      card.style.setProperty('--mx', ((e.clientX - r.left) / r.width * 100) + '%');
      card.style.setProperty('--my', ((e.clientY - r.top) / r.height * 100) + '%');
    });
  });

  /* ════════════ Reveal observer ════════════ */
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('shown'); obs.unobserve(e.target); }
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

  /* ════════════ Nav spy ════════════ */
  const navLinks = document.querySelectorAll('.nav-link');
  const spy = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const id = e.target.id;
        navLinks.forEach(l => l.classList.toggle('active', l.getAttribute('href') === '#' + id));
      }
    });
  }, { rootMargin: '-40% 0px -55% 0px' });
  document.querySelectorAll('section[id]').forEach(s => spy.observe(s));

  /* ════════════ Project modals ════════════ */
  (function() {
    const overlay = document.getElementById('proj-modal');
    const content = document.getElementById('proj-modal-content');
    const closeBtn = document.getElementById('proj-modal-close');

    function openModal(id) {
      const tpl = document.getElementById('tpl-' + id);
      if (!tpl) return;
      content.innerHTML = '';
      content.appendChild(tpl.content.cloneNode(true));
      // Re-apply i18n to freshly cloned template content
      if (window.currentLang === 'en' && window.T && window.T.en) {
        content.querySelectorAll('[data-i18n]').forEach(el => {
          const key = el.getAttribute('data-i18n');
          if (window.T.en[key] !== undefined) el.innerHTML = window.T.en[key];
        });
      }
      overlay.classList.add('open');
      document.body.style.overflow = 'hidden';
      initGallery();
    }

    function closeModal() {
      overlay.classList.remove('open');
      document.body.style.overflow = '';
    }

    function initGallery() {
      const gallery = content.querySelector('.modal-gallery');
      if (!gallery) return;
      const slides = gallery.querySelectorAll('.gal-slide');
      const dots   = gallery.querySelectorAll('.gal-dot');
      if (slides.length <= 1) return;
      let idx = 0;
      function show(i) {
        slides.forEach((s, n) => s.classList.toggle('active', n === i));
        dots.forEach((d, n) => d.classList.toggle('active', n === i));
        idx = i;
      }
      gallery.querySelector('.gal-prev')?.addEventListener('click', (e) => {
        e.stopPropagation();
        show((idx - 1 + slides.length) % slides.length);
      });
      gallery.querySelector('.gal-next')?.addEventListener('click', (e) => {
        e.stopPropagation();
        show((idx + 1) % slides.length);
      });
      dots.forEach((d, n) => d.addEventListener('click', (e) => { e.stopPropagation(); show(n); }));
      show(0);
    }

    // Open on card click (skip if clicking a link/button)
    document.querySelectorAll('.proj-clickable').forEach(card => {
      card.addEventListener('click', (e) => {
        if (e.target.closest('a, button')) return;
        openModal(card.dataset.modal);
      });
    });

    // Close handlers
    closeBtn?.addEventListener('click', closeModal);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
  })();

  /* ════════════ Multi-step contact form ════════════ */
  (function() {
    const form = document.getElementById('ms-form');
    if (!form) return;
    const bar    = document.getElementById('ms-bar');
    const curEl  = document.getElementById('ms-cur');
    const backBtn = document.getElementById('ms-back');
    const submitBtn = document.getElementById('ms-submit');
    const TOTAL = 6;
    let step = 1;
    const answers = {};

    function showStep(n) {
      form.querySelectorAll('.ms-step').forEach(s => s.classList.remove('active'));
      const target = form.querySelector(`.ms-step[data-step="${n}"]`);
      if (target) target.classList.add('active');
      if (curEl) curEl.textContent = String(n).padStart(2, '0');
      if (bar) bar.style.width = (Math.min(n, TOTAL) / TOTAL * 100) + '%';
      if (backBtn) {
        if (n > 1 && n <= TOTAL) backBtn.classList.add('vis');
        else backBtn.classList.remove('vis');
      }
      step = n;
    }

    form.querySelectorAll('.ms-opt').forEach(btn => {
      btn.addEventListener('click', () => {
        const field = btn.dataset.field;
        form.querySelectorAll(`.ms-opt[data-field="${field}"]`).forEach(b => b.classList.remove('sel'));
        btn.classList.add('sel');
        answers[field] = btn.dataset.val;
        setTimeout(() => showStep(step + 1), 260);
      });
    });

    backBtn?.addEventListener('click', () => { if (step > 1) showStep(step - 1); });

    submitBtn?.addEventListener('click', async () => {
      const name  = document.getElementById('ms-name')?.value.trim();
      const email = document.getElementById('ms-email')?.value.trim();
      const msg   = document.getElementById('ms-msg')?.value.trim();
      if (!name || !email) {
        if (!name) document.getElementById('ms-name')?.focus();
        else document.getElementById('ms-email')?.focus();
        return;
      }
      const origText = submitBtn.innerHTML;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Enviando...';
      try {
        const res = await fetch('https://formspree.io/f/mayzpleg', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({
            name, email,
            _subject: `Lead — ${answers.ecommerce || '?'} · ${answers.automatizar || '?'} · ${answers.pais || '?'}`,
            ecommerce:   answers.ecommerce   || '—',
            automatizar: answers.automatizar || '—',
            pedidos_mes: answers.pedidos     || '—',
            pais:        answers.pais        || '—',
            presupuesto: answers.presupuesto || '—',
            comentarios: msg || '—'
          })
        });
        if (res.ok) { showStep(7); }
        else { submitBtn.disabled = false; submitBtn.innerHTML = origText; }
      } catch { submitBtn.disabled = false; submitBtn.innerHTML = origText; }
    });

    showStep(1);
  })();
</script>
