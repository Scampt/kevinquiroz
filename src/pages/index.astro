  // Extend Layout translations with page-level ones
  window.pageTranslations = t;

  // Apply page translations on lang change
  function applyPageLang(lang) {
    const dict = t[lang] || t.es;
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      if (dict[key]) el.textContent = dict[key];
    });
    document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
      const key = el.getAttribute('data-i18n-placeholder');
      if (dict[key]) el.placeholder = dict[key];
    });
    // Hero bio
    const bio = document.getElementById('hero-bio');
    if (bio) {
      bio.textContent = lang === 'en'
        ? "No-Code Automation Specialist & QA Analyst with hands-on experience designing, testing and maintaining complex workflows and integrations. Specialised in n8n, Zapier, Make and OpenAI. Morelos, México."
        : "No-Code Automation Specialist & QA Analyst con experiencia práctica diseñando, testeando y manteniendo workflows complejos e integraciones. Especializado en n8n, Zapier, Make y OpenAI. Morelos, México.";
    }
  }

  document.addEventListener('langchange', (e) => {
    applyPageLang(e.detail.lang);
  });

  document.addEventListener('DOMContentLoaded', () => {
    const lang = localStorage.getItem('kq-lang') || 'es';
    applyPageLang(lang);
  });

  // ── Typewriter ────────────────────────────────────────────────────────────
  const roles = ["Automation Specialist", "QA Analyst", "Frontend Developer", "No-Code Builder"];
  let roleIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  const el = document.getElementById('typewriter-text');

  function typeWriter() {
    if (!el) return;
    const current = roles[roleIndex];
    if (isDeleting) {
      el.textContent = current.substring(0, charIndex - 1);
      charIndex--;
    } else {
      el.textContent = current.substring(0, charIndex + 1);
      charIndex++;
    }

    let speed = isDeleting ? 60 : 100;

    if (!isDeleting && charIndex === current.length) {
      speed = 2000;
      isDeleting = true;
    } else if (isDeleting && charIndex === 0) {
      isDeleting = false;
      roleIndex = (roleIndex + 1) % roles.length;
      speed = 400;
    }

    setTimeout(typeWriter, speed);
  }

  setTimeout(typeWriter, 800);

  // ── IntersectionObserver for fade-in ─────────────────────────────────────
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );

  document.querySelectorAll('.fade-in, .fade-in-stagger').forEach(el => {
    observer.observe(el);
  });
</script>
